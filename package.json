{
  "name": "debaterai",
  "version": "0.1.0",
  "description": "AI agents debate and code together. Claude + Codex real-time collaboration IDE.",
  "main": "dist/main/index.js",
  "author": "sjk0503",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsx watch src/main/index.ts",
    "dev:renderer": "vite dev",
    "build": "vite build",
    "build:all": "npm run build && npm run package",
    "package": "npm run build && electron-builder --mac --universal",
    "package:arm64": "npm run build && electron-builder --mac --arm64",
    "package:x64": "npm run build && electron-builder --mac --x64",
    "start": "electron ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@monaco-editor/react": "^4.7.0",
    "electron-conf": "^1.3.0",
    "electron-store": "^10.0.0",
    "monaco-editor": "^0.52.0",
    "openai": "^4.80.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0"
  }
}
